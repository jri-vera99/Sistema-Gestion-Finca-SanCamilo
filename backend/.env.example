# Base de datos MySQL en Railway
DB_HOST=tu_host_railway
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=railway

# Servidor Express
PORT=3000

# JWT
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_aleatoria
JWT_EXPIRES_IN=8h

# Archivos subidos
UPLOAD_DIR=./uploads

# Ambiente
NODE_ENV=development
